<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="LOJA - Materiais de Construção">
      <%= assigns[:page_title] || "LOJA" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}></script>
  </head>
  <body>
    <!-- Navbar -->
    <header class="border-b bg-white shadow-sm">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3">
        <a href="/" class="text-xl font-bold text-blue-900">LOJA</a>
        <nav class="flex gap-6">
          <a href="/catalogo" class="text-gray-600 hover:text-blue-900">Catálogo</a>
          <a href="/consultor" class="text-gray-600 hover:text-blue-900">Consultor</a>
          <a href="/carrinho" class="text-gray-600 hover:text-blue-900">Carrinho</a>
        </nav>
      </div>
    </header>

    <!-- Conteúdo -->
    <main>
      {@inner_content}
    </main>

    <!-- Footer -->
    <footer class="mt-12 border-t bg-gray-50 py-8">
      <div class="mx-auto max-w-7xl px-4 text-center text-sm text-gray-500">
        <p>LOJA — Materiais de Construção © 2026</p>
      </div>
    </footer>
  </body>
</html>
